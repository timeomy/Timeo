# ─── PostgreSQL ─────────────────────────────────────────────────────────────
# For local dev, docker-compose.yml hardcodes timeo/timeo — only needed for
# running the API or scripts outside Docker.
DATABASE_URL=postgresql://timeo:timeo@localhost:5432/timeo

# ─── Redis ──────────────────────────────────────────────────────────────────
# No password for local dev. For production, set a password.
REDIS_URL=redis://localhost:6379

# ─── API Server ─────────────────────────────────────────────────────────────
API_URL=http://localhost:4000
PORT=4000

# ─── Auth (Better Auth) ────────────────────────────────────────────────────
# Must be at least 32 characters
BETTER_AUTH_SECRET=change-me-to-a-real-secret-min-32chars
JWT_SECRET=change-me-to-a-real-jwt-secret-32chars
SITE_URL=http://localhost:3000

# ─── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_APP_SCHEME=timeo

# ─── Stripe ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Revenue Monster (Malaysia FPX/eWallets) ──────────────────────────────
REVENUE_MONSTER_CLIENT_ID=
REVENUE_MONSTER_CLIENT_SECRET=
REVENUE_MONSTER_PRIVATE_KEY_PATH=./keys/rm-private.pem
REVENUE_MONSTER_PUBLIC_KEY_PATH=./keys/rm-public.pem
REVENUE_MONSTER_STORE_ID=
REVENUE_MONSTER_ENVIRONMENT=sandbox

# ─── Email (Nodemailer / Brevo SMTP) ──────────────────────────────────────
# Brevo free tier: 300 emails/day. Sign up at https://brevo.com
# SMTP details: Settings > SMTP & API > SMTP tab
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login@example.com
SMTP_PASS=your-brevo-smtp-key
EMAIL_FROM=noreply@timeo.my

# ─── Notifications (Novu) ─────────────────────────────────────────────────
NOVU_API_KEY=

# ─── Analytics (PostHog) ──────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Malaysia e-Invoice (MyInvois / LHDN) ────────────────────────────────
MYINVOIS_CLIENT_ID=
MYINVOIS_CLIENT_SECRET=
MYINVOIS_ENVIRONMENT=sandbox

# ─── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS and Socket.io
ALLOWED_ORIGINS=http://localhost:3000

# ─── Turnstile / Face Recognition (MQTT) ────────────────────────────────
# Optional. Set MQTT_BROKER_URL to enable turnstile device communication.
# For testing with supplier's broker: mqtt://47.108.73.83:1883
# For production: set up your own Mosquitto broker or use a managed service.
MQTT_BROKER_URL=
MQTT_USERNAME=device
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=topic/face/manage

# ─── Gym Device Authentication ──────────────────────────────────────────
# Secret for HMAC-signing QR codes and authenticating device API calls.
# Used by X-Device-Key header validation and QR code generation/verification.
GYM_DEVICE_KEY_SECRET=change-me-to-a-random-secret

# ─── Docker / Production Secrets ──────────────────────────────────────────
# Only needed for docker-compose.prod.yml. Generate with: ./scripts/generate-secrets.sh
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# ─── Deployment ────────────────────────────────────────────────────────────
NODE_ENV=development
