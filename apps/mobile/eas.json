{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:4000",
        "EXPO_PUBLIC_APP_SCHEME": "timeo"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.timeo.my",
        "EXPO_PUBLIC_APP_SCHEME": "timeo"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "22.22.1",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.timeo.my",
        "EXPO_PUBLIC_APP_SCHEME": "timeo"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
